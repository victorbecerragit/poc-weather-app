---
import "../styles/global.css";

const latitude = 45.18;
const longitude = 9.15;
const timezone = "Europe/Rome";
const currentFields =
  "temperature_2m,relative_humidity_2m,wind_speed_10m,wind_direction_10m,precipitation,weathercode";
const apiUrl = `https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&timezone=${timezone}&current=${currentFields}`;

type CurrentWeather = {
  time: string;
  temperature_2m: number;
  relative_humidity_2m: number;
  wind_speed_10m: number;
  wind_direction_10m: number;
  precipitation: number;
  weathercode: number;
};

type ApiResponse = {
  current?: CurrentWeather;
};

const emojiMap: Record<number, string> = {
  0: "\u2600\uFE0F",
  1: "\u{1F324}\uFE0F",
  2: "\u26C5",
  3: "\u2601\uFE0F",
  45: "\u{1F32B}\uFE0F",
  48: "\u{1F32B}\uFE0F",
  51: "\u{1F326}\uFE0F",
  53: "\u{1F326}\uFE0F",
  55: "\u{1F326}\uFE0F",
  61: "\u{1F327}\uFE0F",
  63: "\u{1F327}\uFE0F",
  65: "\u{1F327}\uFE0F",
  71: "\u{1F328}\uFE0F",
  73: "\u{1F328}\uFE0F",
  75: "\u{1F328}\uFE0F",
  80: "\u{1F327}\uFE0F",
  81: "\u{1F327}\uFE0F",
  82: "\u{1F327}\uFE0F",
  85: "\u{1F328}\uFE0F",
  86: "\u{1F328}\uFE0F",
  95: "\u26C8\uFE0F",
  96: "\u26C8\uFE0F",
  99: "\u26C8\uFE0F"
};

const defaultWeather: CurrentWeather = {
  time: "--",
  temperature_2m: 0,
  relative_humidity_2m: 0,
  wind_speed_10m: 0,
  wind_direction_10m: 0,
  precipitation: 0,
  weathercode: 0
};

function getEmoji(code: number): string {
  return emojiMap[code] ?? "\u2754";
}

let current: CurrentWeather = defaultWeather;
let status = "Live";

try {
  const response = await fetch(apiUrl);
  if (response.ok) {
    const json = (await response.json()) as ApiResponse;
    if (json.current) {
      current = json.current;
    } else {
      status = "No current data";
    }
  } else {
    status = "API unavailable";
  }
} catch (error) {
  status = "Fetch failed";
}

const emoji = getEmoji(current.weathercode);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Weather Pavia</title>
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div class="hero__badge">
          <span>Weather Pavia Live</span>
          <span class="hero__status">{status}</span>
        </div>
        <h1>Concrete Skies over Pavia</h1>
        <div class="hero__summary">
          <div class="temp">
            <div class="temp__emoji">{emoji}</div>
            <div class="temp__value">{current.temperature_2m.toFixed(1)}</div>
            <div class="temp__unit">°C</div>
            <div class="temp__time">Updated {current.time}</div>
          </div>
          <p>
            Real-time conditions for Pavia, Italy. Updated directly from Open-Meteo and
            reflected in the repository README.
          </p>
        </div>
      </section>

      <section class="grid">
        <article class="card">
          <div class="card__title">Humidity</div>
          <div class="card__value">{current.relative_humidity_2m.toFixed(0)}%</div>
          <div class="card__meta">Relative humidity</div>
        </article>

        <article class="card">
          <div class="card__title">Wind</div>
          <div class="card__value">{current.wind_speed_10m.toFixed(1)} km/h</div>
          <div class="card__meta">Direction {current.wind_direction_10m.toFixed(0)}°</div>
        </article>

        <article class="card">
          <div class="card__title">Precipitation</div>
          <div class="card__value">{current.precipitation.toFixed(1)} mm</div>
          <div class="card__meta">Last hour</div>
        </article>
      </section>

      <section class="footer">
        <div>
          <strong>Coordinates</strong>
          <span>45.18, 9.15</span>
        </div>
        <div>
          <strong>Timezone</strong>
          <span>Europe/Rome</span>
        </div>
        <div>
          <strong>API</strong>
          <span>Open-Meteo</span>
        </div>
      </section>
    </main>
  </body>
</html>
