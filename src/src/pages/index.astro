---
const latitude = 45.18;
const longitude = 9.15;
const timezone = "Europe/Rome";
const currentFields =
  "temperature_2m,relative_humidity_2m,wind_speed_10m,wind_direction_10m,precipitation,weathercode";
const apiUrl = `https://api.open-meteo.com/v1/forecast?latitude=${latitude}&longitude=${longitude}&timezone=${timezone}&current=${currentFields}`;

type CurrentWeather = {
  time: string;
  temperature_2m: number;
  relative_humidity_2m: number;
  wind_speed_10m: number;
  wind_direction_10m: number;
  precipitation: number;
  weathercode: number;
};

type ApiResponse = {
  current?: CurrentWeather;
};

const emojiMap: Record<number, string> = {
  0: "\u2600\ufe0f",
  1: "\ud83c\udf24\ufe0f",
  2: "\u26c5",
  3: "\u2601\ufe0f",
  45: "\ud83c\udf2b\ufe0f",
  48: "\ud83c\udf2b\ufe0f",
  51: "\ud83c\udf26\ufe0f",
  53: "\ud83c\udf26\ufe0f",
  55: "\ud83c\udf26\ufe0f",
  61: "\ud83c\udf27\ufe0f",
  63: "\ud83c\udf27\ufe0f",
  65: "\ud83c\udf27\ufe0f",
  71: "\ud83c\udf28\ufe0f",
  73: "\ud83c\udf28\ufe0f",
  75: "\ud83c\udf28\ufe0f",
  80: "\ud83c\udf27\ufe0f",
  81: "\ud83c\udf27\ufe0f",
  82: "\ud83c\udf27\ufe0f",
  85: "\ud83c\udf28\ufe0f",
  86: "\ud83c\udf28\ufe0f",
  95: "\u26c8\ufe0f",
  96: "\u26c8\ufe0f",
  99: "\u26c8\ufe0f"
};

const defaultWeather: CurrentWeather = {
  time: "--",
  temperature_2m: 0,
  relative_humidity_2m: 0,
  wind_speed_10m: 0,
  wind_direction_10m: 0,
  precipitation: 0,
  weathercode: 0
};

function getEmoji(code: number): string {
  return emojiMap[code] ?? "\u2754";
}

let current: CurrentWeather = defaultWeather;
let status = "Live";

try {
  const response = await fetch(apiUrl);
  if (response.ok) {
    const json = (await response.json()) as ApiResponse;
    if (json.current) {
      current = json.current;
    } else {
      status = "No current data";
    }
  } else {
    status = "API unavailable";
  }
} catch (error) {
  status = "Fetch failed";
}

const emoji = getEmoji(current.weathercode);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Weather Pavia</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <main class="page">
      <section class="hero">
        <div class="hero__badge">
          <span>Weather Pavia</span>
          <span class="hero__status">{status}</span>
        </div>
        <h1>Concrete Skies over Pavia</h1>
        <p>
          Real-time conditions for Pavia, Italy. Updated directly from Open-Meteo with
          a weather table in the repository README.
        </p>
      </section>

      <section class="grid">
        <article class="card card--primary">
          <div class="card__title">Current Conditions</div>
          <div class="card__value">
            {emoji}
            <span>{current.temperature_2m.toFixed(1)}°C</span>
          </div>
          <div class="card__meta">Updated {current.time}</div>
        </article>

        <article class="card">
          <div class="card__title">Humidity</div>
          <div class="card__value">
            <span>{current.relative_humidity_2m.toFixed(0)}%</span>
          </div>
          <div class="card__meta">Relative humidity</div>
        </article>

        <article class="card">
          <div class="card__title">Wind</div>
          <div class="card__value">
            <span>{current.wind_speed_10m.toFixed(1)} km/h</span>
          </div>
          <div class="card__meta">Direction {current.wind_direction_10m.toFixed(0)}°</div>
        </article>

        <article class="card">
          <div class="card__title">Precipitation</div>
          <div class="card__value">
            <span>{current.precipitation.toFixed(1)} mm</span>
          </div>
          <div class="card__meta">Last hour</div>
        </article>
      </section>

      <section class="footer">
        <div>
          <strong>Coordinates</strong>
          <span>45.18, 9.15</span>
        </div>
        <div>
          <strong>Timezone</strong>
          <span>Europe/Rome</span>
        </div>
        <div>
          <strong>API</strong>
          <span>Open-Meteo</span>
        </div>
      </section>
    </main>
  </body>
</html>
